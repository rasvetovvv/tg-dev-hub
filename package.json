{
  "name": "tg-dev-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot and Mini App marketplace for scripts, source code and developer projects with Telegram Stars payments.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rasvetovvv/tg-dev-hub.git"
  },
  "homepage": "https://github.com/rasvetovvv/tg-dev-hub#readme",
  "bugs": {
    "url": "https://github.com/rasvetovvv/tg-dev-hub/issues"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch src/server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node src/server/index.js",
    "check": "npm run build && node --check src/server/index.js && node --check src/server/config.js && node --check src/server/db.js && node --check src/server/security.js && node --check src/server/storage.js && node --check src/server/fileSecurity.js && node --check src/server/botCommands.js",
    "test:functional": "node work/full-functional-check.mjs"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.468.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": ">=24"
  }
}
