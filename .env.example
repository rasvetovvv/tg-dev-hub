NODE_ENV=production
PORT=7870

# Token from @BotFather.
BOT_TOKEN=123456789:replace_me
BOT_USERNAME=your_bot_username_without_at
# Optional Mini App short name from BotFather. If empty, public links open the bot with /start payload.
BOT_APP_NAME=devhub

# Public HTTPS URL where the WebApp is available.
# Example: https://devhub.example.com
WEBAPP_URL=https://your-domain.example

# Comma-separated Telegram numeric IDs that can publish projects.
# Use /id in the bot to see your ID.
ADMIN_TELEGRAM_IDS=123456789

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_random_hex_chars

DB_PATH=/app/data/app.sqlite
UPLOADS_DIR=/app/data/uploads
MAX_UPLOAD_MB=100

# Keep false on a real VPS.
ALLOW_DEV_AUTH=false

# --- Monetization ---
# Daily download cap for regular users (VIP and subscribers are unlimited).
FREE_DAILY_DOWNLOAD_LIMIT=5
# Subscription plan: length and price in Telegram Stars.
SUBSCRIPTION_DAYS=30
SUBSCRIPTION_STARS=499
# VIP plan: VIP_DAYS=0 means a permanent VIP grant.
VIP_DAYS=0
VIP_STARS=1990
# When true, "buy / subscribe / VIP" grant access instantly (no payment provider).
# Keep false in production: checkout will use Telegram Stars invoices.
ALLOW_TEST_CHECKOUT=false
